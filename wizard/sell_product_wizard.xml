<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sell_product_form" model="ir.ui.view">
        <field name="name">sell.product.form</field>
        <field name="model">sell.product.wizard</field>
        <field name="arch" type="xml">
            <form string="sell Product Wizard">
                <group>
                    <field name="product_id"/>
                    <field name="qty_to_sell"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            string="Sell"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>