<odoo>
<data>
    <record id="shop_product_form" model="ir.ui.view">
        <field name="name">Shop product Form</field>
        <field name="model">shop.product</field>
        <field name="arch" type="xml">
            <form name="product_form">
                <header>
                    <button string = 'Sell' type='object' name='action_sell'/>
                    <button string="Restock" type="object" name="action_restock"/>
                </header>
                <group> 
                    <field name="name"/>
                    <field name="category"/>
                    <field name="price"/>
                    <field name="quantity"/>
                    <field name="min_stock_level"/>
                </group>
            </form>
        </field>
    </record>

<record id="view_shop_product_search" model="ir.ui.view">
    <field name="name">shop.product.search</field>
    <field name="model">shop.product</field>
    <field name="arch" type="xml">
        <search string="Search products">

            <!-- Searchable fields (shown as autocomplete in the search bar) -->
            <field name="name"/>
            <field name="category"/>

            <!-- Filters -->
            <separator/>
            <filter string="Low Stock" name="filter_low_stock"
                domain="[('is_low_stock', '=', True)]"/>

            <separator/>
            <filter string="Under ₹500" name="filter_price_low"
                domain="[('price', '&lt;=', 500)]"/>
            <filter string="₹500 to ₹2000" name="filter_price_mid"
                domain="[('price', '&gt;=', 500), ('price', '&lt;=', 2000)]"/>
            <filter string="Over ₹2000" name="filter_price_high"
                domain="[('price', '&gt;=', 2000)]"/>

            <!-- Group By -->
            <group expand="0" string="Group By">
                <filter string="Category" name="group_by_category"
                    context="{'group_by': 'category'}"/>
            </group>

        </search>
    </field>
</record>

    <record id="shop_product_list" model='ir.ui.view'>
        <field name="name">Shop product list</field>
        <field name="model">shop.product</field>
        <field name="arch" type='xml'>
            <list name='product_list'>
                <field name="name"/>
                <field name="category"/>
                <field name="price"/>
                <field name="quantity"/>
                <field name="min_stock_level"/>
            </list>
        </field>
    </record>

    <record id="action_shop_product" model="ir.actions.act_window">
        <field name="name">Shop product</field>
        <field name="res_model">shop.product</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_shop_product" name="product" parent="menu_shop_root" action="action_shop_product" sequence="11"/>

</data>
</odoo>