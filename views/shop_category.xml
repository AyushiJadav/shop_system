<odoo>
<data>
    <record id="shop_category_form" model="ir.ui.view">
    <field name="name">Shop Category Form</field>
    <field name="model">shop.category</field>
    <field name="arch" type="xml">
        <form name="category_form">
            <group> 
                <field name="name"/>
            </group>
        </form>
    </field>
    </record>

    <record id="shop_category_list" model='ir.ui.view'>
    <field name="name">Shop Category list</field>
    <field name="model">shop.category</field>
    <field name="arch" type='xml'>
        <list name='category_list'>
            <field name="name"/>
        </list>
    </field>
    </record>

    <record id="action_shop_category" model="ir.actions.act_window">
        <field name="name">Shop Category</field>
        <field name="res_model">shop.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_shop_root" name="Shop Inventory System" sequence="10"/>

    <menuitem id="menu_shop_category" name="Category" parent="menu_shop_root" action="action_shop_category" sequence="11"/>
</data>
</odoo>